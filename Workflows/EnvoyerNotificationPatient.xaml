<?xml version="1.0" encoding="utf-8"?>
<Activity mc:Ignorable="sap sap2010 sads"
  x:Class="UiPath.RDV.EnvoyerNotificationPatient"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:sads="http://schemas.microsoft.com/netfx/2010/xaml/activities/debugger"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=mscorlib"
  xmlns:sd="clr-namespace:System.Data;assembly=System.Data"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <x:Members>
    <x:Property Name="in_Config"      Type="InArgument(scg:Dictionary(x:String, x:Object))"/>
    <x:Property Name="in_PatientNom"  Type="InArgument(x:String)"/>
    <x:Property Name="in_DateRDV"     Type="InArgument(x:String)"/>
    <x:Property Name="in_HeureRDV"    Type="InArgument(x:String)"/>
  </x:Members>

  <Sequence DisplayName="Envoyer Notification Confirmation Patient" sap:VirtualizedContainerService.HintSize="700,500">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="v_SujetEmail"/>
      <Variable x:TypeArguments="x:String" Name="v_CorpsEmail"/>
      <Variable x:TypeArguments="x:String" Name="v_EmailExpediteur"/>
      <Variable x:TypeArguments="x:String" Name="v_EmailDestinataire"/>
      <Variable x:TypeArguments="x:String" Name="v_CheminLog"/>
    </Sequence.Variables>

    <!-- Construire l'email -->
    <Assign DisplayName="[SET] Expéditeur email">
      <Assign.To><OutArgument x:TypeArguments="x:String"><x:Reference Name="v_EmailExpediteur"/></OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[CStr(in_Config("EmailCabinet"))]</InArgument></Assign.Value>
    </Assign>

    <Assign DisplayName="[SET] Destinataire email (lookup depuis dossier)">
      <Assign.To><OutArgument x:TypeArguments="x:String"><x:Reference Name="v_EmailDestinataire"/></OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[CStr(in_Config("EmailTestPatient"))]</InArgument></Assign.Value>
    </Assign>

    <Assign DisplayName="[SET] Sujet email">
      <Assign.To><OutArgument x:TypeArguments="x:String"><x:Reference Name="v_SujetEmail"/></OutArgument></Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">
          ["[CABINET MÉDICAL] Confirmation de votre rendez-vous – " + in_DateRDV + " à " + in_HeureRDV]
        </InArgument>
      </Assign.Value>
    </Assign>

    <Assign DisplayName="[SET] Corps email">
      <Assign.To><OutArgument x:TypeArguments="x:String"><x:Reference Name="v_CorpsEmail"/></OutArgument></Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">
          ["Bonjour " + in_PatientNom + "," + Environment.NewLine + Environment.NewLine +
           "Votre rendez-vous médical est confirmé :" + Environment.NewLine +
           "  📅 Date  : " + in_DateRDV + Environment.NewLine +
           "  🕐 Heure : " + in_HeureRDV + Environment.NewLine + Environment.NewLine +
           "Merci de vous présenter 5 minutes avant l'heure prévue." + Environment.NewLine +
           "En cas d'empêchement, veuillez nous contacter au plus tôt." + Environment.NewLine + Environment.NewLine +
           "Cordialement," + Environment.NewLine +
           "Le Cabinet Médical" + Environment.NewLine +
           "🤖 Message généré automatiquement par le système RPA"]
        </InArgument>
      </Assign.Value>
    </Assign>

    <!-- Envoyer email SMTP -->
    <ui:SendSMTPMail DisplayName="[EMAIL] Envoyer confirmation patient"
      From="[v_EmailExpediteur]"
      To="[v_EmailDestinataire]"
      Subject="[v_SujetEmail]"
      Body="[v_CorpsEmail]"
      Port="[CInt(in_Config(&quot;SmtpPort&quot;))]"
      Server="[CStr(in_Config(&quot;SmtpServer&quot;))]"
      Password="[CStr(in_Config(&quot;SmtpPassword&quot;))]"
      IsBodyHtml="False"/>

    <ui:LogMessage Level="Info"
      Message="[&quot;[RPA-RDV] ✅ Email de confirmation envoyé à : &quot; + v_EmailDestinataire]"/>

    <!-- Logger dans fichier log Excel -->
    <Assign DisplayName="[SET] Chemin Log">
      <Assign.To><OutArgument x:TypeArguments="x:String"><x:Reference Name="v_CheminLog"/></OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[CStr(in_Config("ExcelLogPath"))]</InArgument></Assign.Value>
    </Assign>

    <ui:ExcelApplicationScope DisplayName="[EXCEL] Écrire dans Log" WorkbookPath="[v_CheminLog]">
      <ui:ExcelApplicationScope.Body>
        <ActivityAction>
          <ActivityAction.Argument>
            <DelegateInArgument x:TypeArguments="ui:WorkbookApplication" Name="ExcelWorkbook"/>
          </ActivityAction.Argument>
          <Sequence>
            <ui:AppendRange DisplayName="[EXCEL] Ajouter ligne dans Log"
              SheetName="Log"
              StartingCell="A1"
              DataTable="[New System.Data.DataTable() With {
                .Columns = {New System.Data.DataColumn(&quot;Timestamp&quot;), New System.Data.DataColumn(&quot;Patient&quot;), New System.Data.DataColumn(&quot;Date&quot;), New System.Data.DataColumn(&quot;Heure&quot;), New System.Data.DataColumn(&quot;Statut&quot;)},
                .Rows = { {DateTime.Now.ToString(&quot;dd/MM/yyyy HH:mm:ss&quot;), in_PatientNom, in_DateRDV, in_HeureRDV, &quot;Email Envoyé&quot;} }
              }]"/>
            <ui:Save DisplayName="[EXCEL] Sauvegarder Log"/>
          </Sequence>
        </ActivityAction>
      </ui:ExcelApplicationScope.Body>
    </ui:ExcelApplicationScope>

  </Sequence>
</Activity>
