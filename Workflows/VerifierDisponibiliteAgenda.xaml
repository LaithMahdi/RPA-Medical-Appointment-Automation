<?xml version="1.0" encoding="utf-8"?>
<Activity mc:Ignorable="sap sap2010 sads"
  x:Class="UiPath.RDV.VerifierDisponibiliteAgenda"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:sads="http://schemas.microsoft.com/netfx/2010/xaml/activities/debugger"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=mscorlib"
  xmlns:sd="clr-namespace:System.Data;assembly=System.Data"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <x:Members>
    <x:Property Name="in_Config"                  Type="InArgument(scg:Dictionary(x:String, x:Object))"/>
    <x:Property Name="out_DateRDV"                Type="OutArgument(x:String)"/>
    <x:Property Name="out_HeureRDV"               Type="OutArgument(x:String)"/>
    <x:Property Name="out_DisponibiliteTrouvee"   Type="OutArgument(x:Boolean)"/>
  </x:Members>

  <Sequence DisplayName="Vérifier Disponibilité Agenda Médecin" sap:VirtualizedContainerService.HintSize="700,700">
    <Sequence.Variables>
      <Variable x:TypeArguments="sd:DataTable"  Name="dt_Agenda"/>
      <Variable x:TypeArguments="x:String"      Name="v_CheminAgenda"/>
      <Variable x:TypeArguments="x:Boolean"     Name="v_Trouve" Default="False"/>
      <Variable x:TypeArguments="x:String"      Name="v_Date"   Default=""/>
      <Variable x:TypeArguments="x:String"      Name="v_Heure"  Default=""/>
    </Sequence.Variables>

    <!-- Récupérer chemin Agenda -->
    <Assign DisplayName="[SET] Chemin fichier Agenda">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">[v_CheminAgenda]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">
          [CStr(in_Config("ExcelAgendaPath"))]
        </InArgument>
      </Assign.Value>
    </Assign>

    <ui:LogMessage Level="Info"
      Message="[&quot;[RPA-RDV] Consultation de l'agenda : &quot; + v_CheminAgenda]"/>

    <!-- Ouvrir Excel Agenda -->
    <ui:ExcelApplicationScope DisplayName="[EXCEL] Ouvrir Agenda Médecin"
      WorkbookPath="[v_CheminAgenda]">
      <ui:ExcelApplicationScope.Body>
        <ActivityAction x:TypeArguments="ui:WorkbookApplication">
          <ActivityAction.Argument>
            <DelegateInArgument x:TypeArguments="ui:WorkbookApplication" Name="ExcelWorkbook"/>
          </ActivityAction.Argument>
          <Sequence>

            <!-- Lire feuille Agenda -->
            <ui:ReadRange DisplayName="[EXCEL] Lire feuille Agenda"
              SheetName="Agenda"
              Range=""
              AddHeaders="True">
              <ui:ReadRange.DataTable>
                <OutArgument x:TypeArguments="sd:DataTable">[dt_Agenda]</OutArgument>
              </ui:ReadRange.DataTable>
            </ui:ReadRange>

          </Sequence>
        </ActivityAction>
      </ui:ExcelApplicationScope.Body>
    </ui:ExcelApplicationScope>

    <!-- Chercher un créneau libre (Statut = "Libre") -->
    <ForEach x:TypeArguments="sd:DataRow" DisplayName="[LOOP] Chercher créneau disponible"
      Values="[dt_Agenda.Select(&quot;Statut = 'Libre'&quot;).OrderBy(Function(r) r(&quot;Date&quot;).ToString).Take(1).ToArray]">
      <ActivityAction x:TypeArguments="sd:DataRow">
        <ActivityAction.Argument>
          <DelegateInArgument x:TypeArguments="sd:DataRow" Name="row"/>
        </ActivityAction.Argument>
        <Sequence DisplayName="[ROW] Créneau trouvé">

          <Assign DisplayName="[SET] Date RDV">
            <Assign.To><OutArgument x:TypeArguments="x:String">[v_Date]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">[row("Date").ToString.Trim]</InArgument></Assign.Value>
          </Assign>

          <Assign DisplayName="[SET] Heure RDV">
            <Assign.To><OutArgument x:TypeArguments="x:String">[v_Heure]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">[row("Heure").ToString.Trim]</InArgument></Assign.Value>
          </Assign>

          <Assign DisplayName="[SET] Disponibilité = True">
            <Assign.To><OutArgument x:TypeArguments="x:Boolean">[v_Trouve]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:Boolean"><Literal x:TypeArguments="x:Boolean" Value="True"/></InArgument></Assign.Value>
          </Assign>

          <ui:LogMessage Level="Info"
            Message="[&quot;[RPA-RDV] ✅ Créneau disponible trouvé : &quot; + v_Date + &quot; à &quot; + v_Heure]"/>

        </Sequence>
      </ActivityAction>
    </ForEach>

    <!-- Propager les résultats en sortie -->
    <Assign DisplayName="[OUT] DateRDV">
      <Assign.To><OutArgument x:TypeArguments="x:String">[out_DateRDV]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[v_Date]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="[OUT] HeureRDV">
      <Assign.To><OutArgument x:TypeArguments="x:String">[out_HeureRDV]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[v_Heure]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="[OUT] DisponibiliteTrouvee">
      <Assign.To><OutArgument x:TypeArguments="x:Boolean">[out_DisponibiliteTrouvee]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:Boolean">[v_Trouve]</InArgument></Assign.Value>
    </Assign>

  </Sequence>
</Activity>
