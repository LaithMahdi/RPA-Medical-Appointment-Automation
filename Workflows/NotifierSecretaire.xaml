<?xml version="1.0" encoding="utf-8"?>
<Activity mc:Ignorable="sap sap2010 sads"
  x:Class="UiPath.RDV.NotifierSecretaire"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:sads="http://schemas.microsoft.com/netfx/2010/xaml/activities/debugger"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=mscorlib"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <x:Members>
    <x:Property Name="in_Config"      Type="InArgument(scg:Dictionary(x:String, x:Object))"/>
    <x:Property Name="in_PatientNom"  Type="InArgument(x:String)"/>
  </x:Members>

  <Sequence DisplayName="Notifier Secrétaire – Aucun Créneau Disponible">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="v_Sujet"/>
      <Variable x:TypeArguments="x:String" Name="v_Corps"/>
    </Sequence.Variables>

    <Assign DisplayName="[SET] Sujet alerte secrétaire">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_Sujet]</OutArgument></Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">
          ["[ALERTE RPA] Aucun créneau disponible – Action requise pour : " + in_PatientNom]
        </InArgument>
      </Assign.Value>
    </Assign>

    <Assign DisplayName="[SET] Corps alerte secrétaire">
      <Assign.To><OutArgument x:TypeArguments="x:String">[v_Corps]</OutArgument></Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">
          ["Bonjour," + Environment.NewLine + Environment.NewLine +
           "Le robot RPA n'a trouvé aucun créneau disponible pour le patient : " + in_PatientNom + Environment.NewLine +
           "Une intervention manuelle est requise." + Environment.NewLine + Environment.NewLine +
           "Veuillez consulter l'agenda et contacter le patient pour proposer une date." + Environment.NewLine + Environment.NewLine +
           "🤖 Message automatique – Système RPA Cabinet Médical"]
        </InArgument>
      </Assign.Value>
    </Assign>

    <ui:LogMessage DisplayName="[EMAIL] Simulation alerte secrétaire"
      Level="Warn"
      Message="[&quot;[RPA-RDV] (Simulation) Alerte prête pour secrétaire: &quot; + v_Sujet]"/>

    <ui:LogMessage Level="Warn"
      Message="[&quot;[RPA-RDV] ⚠️ Alerte envoyée à la secrétaire pour le patient : &quot; + in_PatientNom]"/>

  </Sequence>
</Activity>
